# Supabase Local Development
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-local-supabase-publishable-or-anon-key

# Database Local
SUPABASE_DB_PASSWORD=your-super-secret-and-long-postgres-password
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# PostHog Analytics (product analytics — errors go to Sentry)
VITE_POSTHOG_KEY=your-posthog-project-api-key-here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (error tracking)
VITE_SENTRY_DSN=https://your_key@o123.ingest.sentry.io/456
VITE_SENTRY_RELEASE=local-dev

# Supabase Edge Functions secrets (Supabase Dashboard → Edge Functions → Secrets)
# POSTHOG_API_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# GOOGLE_AI_API_KEY=...
# CI only:
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=yo-self-gestor-web

# Admin keys for local scripts only (npm run update-images-cache). NEVER commit real values.
# Prefer SUPABASE_URL here so .env.development can point Vite dev at local Supabase without conflict.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_key_here
# Legacy fallback (deprecated):
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_jwt_here

# Production client keys (also set as GitHub Actions secrets for deploy).
# VITE_* values are public in the browser bundle. Never put service role or secret keys here.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

